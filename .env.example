# --- Storage ---
# Where to write artifacts and read data. local | gcs | s3 | azure_blob
PUFFIN_STORAGE_BACKEND=local
PUFFIN_ARTIFACT_ROOT=./artifacts
PUFFIN_DATA_ROOT=./data

# --- Tracking ---
# mlflow | none
PUFFIN_TRACKING_BACKEND=mlflow
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=puffin-default

# --- Logging ---
PUFFIN_LOG_LEVEL=INFO
PUFFIN_LOG_FORMAT=json
PUFFIN_REDACT_LOGS=false

# --- Serving ---
PUFFIN_SERVE_HOST=0.0.0.0
PUFFIN_SERVE_PORT=8080
PUFFIN_SERVE_BACKEND=transformers
PUFFIN_DISABLE_SAFETY=false

# --- Hugging Face ---
HF_TOKEN=
HF_HOME=./.hf-cache

# --- GCP (set only if using GCP provider) ---
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=
GCP_REGION=us-central1

# --- AWS (set only if using AWS provider) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SAGEMAKER_ROLE_ARN=

# --- Azure (set only if using Azure provider) ---
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=
AZUREML_WORKSPACE_NAME=

# --- Kubernetes ---
PUFFIN_K8S_NAMESPACE=puffin
PUFFIN_K8S_CONTEXT=

# --- Optional W&B ---
WANDB_API_KEY=
WANDB_PROJECT=puffin-default

# --- Provider profile (overrides per-config selection) ---
PUFFIN_PROFILE=local
