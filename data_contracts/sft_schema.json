{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PuffinSFTExample",
  "description": "One supervised fine-tuning example for puffin-finetune-studio.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "source", "messages"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "source": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant", "tool"]
          },
          "content": {
            "type": "string",
            "minLength": 0,
            "maxLength": 200000
          },
          "name": {
            "type": ["string", "null"],
            "maxLength": 256
          },
          "tool_call_id": {
            "type": ["string", "null"],
            "maxLength": 256
          }
        }
      }
    },
    "quality_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "license": {
      "type": "string",
      "maxLength": 64
    },
    "contains_pii": {
      "type": "boolean"
    },
    "created_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
