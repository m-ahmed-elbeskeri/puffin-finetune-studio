# syntax=docker/dockerfile:1.7
# Eval image: data + eval extras only (no training stack).

ARG PYTHON_VERSION=3.11
FROM python:${PYTHON_VERSION}-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
# Copy the package before installing: the editable/hatchling build needs
# src/llmops to exist to resolve the package.
COPY src ./src
RUN pip install --upgrade pip \
    && pip install -e ".[data,eval]"

COPY configs ./configs
COPY eval_sets ./eval_sets
COPY data_contracts ./data_contracts

RUN python -c "import llmops.evaluation.gate, llmops.evaluation.task_eval"

ENTRYPOINT ["python", "-m"]
CMD ["llmops.evaluation.gate", "--help"]
